# ════════════════════════════════════════════════════════════════════════════
# MP Alertas — Variables de entorno
# Copiar este archivo como .env y completar los valores antes de iniciar.
# ════════════════════════════════════════════════════════════════════════════

# ── API Mercado Público ───────────────────────────────────────────────────────
# Solicitar en: https://apis.mercadopublico.cl/
TICKET_MERCADO_PUBLICO=TU_TICKET_AQUI

# URL base de la API (no cambiar salvo que Mercado Público cambie su endpoint)
API_BASE_URL=https://api.mercadopublico.cl/servicios/v1

# Límites de rate limiting (ajustar según tu plan)
API_RATE_PER_SECOND=5
API_RATE_PER_DAY=10000

# ── Base de datos ─────────────────────────────────────────────────────────────
# SQLite (desarrollo / instancia única):
DATABASE_URL=sqlite:///./mercadopublico.db

# PostgreSQL (producción / multi-instancia):
# DATABASE_URL=postgresql://mp_user:mp_pass@db:5432/mp_alertas
# POSTGRES_DB=mp_alertas
# POSTGRES_USER=mp_user
# POSTGRES_PASSWORD=mp_pass

# ── SMTP — Correo electrónico ─────────────────────────────────────────────────
# Gmail con App Password (recomendado):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx    # App Password de Google
SMTP_FROM="MP Alertas <tu@gmail.com>"
SMTP_USE_TLS=true

# SendGrid (alternativa):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxxxxxxx
# SMTP_FROM=noreply@tudominio.cl

# ── Dashboard web ─────────────────────────────────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASS=CAMBIA_ESTO_AHORA      # ← Importante en producción
SECRET_KEY=genera-una-clave-larga-y-aleatoria-aqui

# URL base de la aplicación (para links en correos)
APP_BASE_URL=http://localhost:5000

# ── Notificaciones al administrador ──────────────────────────────────────────
# Recibirá un resumen diario del ciclo del scheduler.
# Dejar vacío para desactivar.
ADMIN_EMAIL=

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Hora de ejecución diaria (zona horaria Chile)
SCHEDULER_HOUR=6
SCHEDULER_MINUTE=0
TIMEZONE=America/Santiago

# ── Configuración de alertas ──────────────────────────────────────────────────
# No reenviar la misma alerta si fue enviada en los últimos N días
ALERT_DEDUP_DAYS=30

# ── Puerto del servidor web ───────────────────────────────────────────────────
PORT=5000
